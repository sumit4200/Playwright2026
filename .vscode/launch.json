{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug calendar test",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "tests/calendar.spec.ts",
        "--headed",
        "--workers=1"
      ],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    }
  ]
}