{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Playwright Debug",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "tests/WebAPIPart1.spec.ts",
        "--headed",
        "--workers=1"
      ],
       
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}